APP_ENV=development
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/myriders?sslmode=disable

# JWT secrets — replace with long random strings in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# CORS — comma-separated origins, or * for open
CORS_ALLOWED_ORIGINS=*
