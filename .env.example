# App Environment
APP_ENV=development
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/trackride?sslmode=disable

# Redis connection string
REDIS_URL=redis://localhost:6379

# JWT secrets — replace with long random strings in production (min 32 chars)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-xxxxxxxx
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-xxxxxxx

# JWT token TTL — use duration format (e.g., 1h, 720h)
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=720h

# WebSocket token TTL in seconds
WS_TOKEN_TTL=600

# Google Maps API Key (optional, for reverse geocoding)
GOOGLE_MAPS_API_KEY=your-key-here
